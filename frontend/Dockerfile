FROM node:24-alpine

WORKDIR /app

ARG NEXT_PUBLIC_API_BASE=""
ARG NEXT_PUBLIC_OPERATOR_NAME=""
ARG NEXT_PUBLIC_OPERATOR_CONTACT=""
ARG NEXT_PUBLIC_DATA_REGION=""
ARG NEXT_PUBLIC_DATA_RETENTION=""
ARG NEXT_PUBLIC_PUBLIC_DISPLAY_NOTICE=""

COPY package*.json ./
RUN npm ci

COPY . .

ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV NEXT_PUBLIC_API_BASE=$NEXT_PUBLIC_API_BASE
ENV NEXT_PUBLIC_OPERATOR_NAME=$NEXT_PUBLIC_OPERATOR_NAME
ENV NEXT_PUBLIC_OPERATOR_CONTACT=$NEXT_PUBLIC_OPERATOR_CONTACT
ENV NEXT_PUBLIC_DATA_REGION=$NEXT_PUBLIC_DATA_REGION
ENV NEXT_PUBLIC_DATA_RETENTION=$NEXT_PUBLIC_DATA_RETENTION
ENV NEXT_PUBLIC_PUBLIC_DISPLAY_NOTICE=$NEXT_PUBLIC_PUBLIC_DISPLAY_NOTICE

RUN npm run build

EXPOSE 3000

CMD ["npm", "start"]
